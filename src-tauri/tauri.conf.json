{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QBWebUIHelper",
  "version": "1.1.0",
  "identifier": "com.kritblade.qbwebuihelper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "name": "Torrent File",
        "description": "BitTorrent file",
        "mimeType": "application/x-bittorrent",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": ["magnet"]
    }
  }
}
